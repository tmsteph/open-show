{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openshow.dev/schema/showfile-v0.json",
  "title": "OpenShow Showfile v0",
  "type": "object",
  "required": ["schemaVersion", "metadata", "outputs", "cues"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "0.1.0"
    },
    "metadata": {
      "type": "object",
      "required": ["showId", "title", "revision", "createdAt"],
      "additionalProperties": false,
      "properties": {
        "showId": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "venue": { "type": "string" },
        "eventDate": { "type": "string", "format": "date" },
        "revision": { "type": "integer", "minimum": 1 },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "outputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "role", "enabled"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "name": { "type": "string", "minLength": 1 },
          "role": {
            "type": "string",
            "enum": ["program", "confidence", "operator"]
          },
          "connector": { "type": "string" },
          "resolution": { "type": "string" },
          "refreshHz": { "type": "number", "minimum": 1 },
          "enabled": { "type": "boolean" }
        }
      }
    },
    "cues": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "type", "name", "outputs"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^Q-[0-9]{3}$" },
          "type": {
            "type": "string",
            "enum": ["PPT", "IMG", "VID", "BLACK", "FREEZE"]
          },
          "name": { "type": "string", "minLength": 1 },
          "notes": { "type": "string" },
          "meta": { "type": "string" },
          "preview": { "type": "string" },
          "outputs": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "transitions": {
            "type": "array",
            "items": { "type": "string" }
          },
          "safety": {
            "type": "array",
            "items": { "type": "string" }
          },
          "asset": {
            "type": "object",
            "additionalProperties": false,
            "required": ["uri"],
            "properties": {
              "uri": { "type": "string", "minLength": 1 },
              "durationMs": { "type": "integer", "minimum": 0 }
            }
          }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "type": { "enum": ["PPT", "IMG", "VID"] }
              }
            },
            "then": { "required": ["asset"] }
          }
        ]
      }
    }
  }
}

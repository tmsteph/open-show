{
  "name": "open-show",
  "version": "0.1.0",
  "private": true,
  "description": "OpenShow browser-first playback MVP",
  "scripts": {
    "start:api": "node scripts/start-api.mjs",
    "lint": "node scripts/lint.mjs",
    "validate:showfile": "node scripts/validate-showfile.mjs fixtures/sample-showfile.json docs/showfile.schema.json",
    "test": "node --test",
    "test:e2e:persistence": "node scripts/playwright-refresh-persistence.mjs",
    "check": "npm run lint && npm run validate:showfile && npm run test"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1"
  },
  "dependencies": {
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7"
  }
}
